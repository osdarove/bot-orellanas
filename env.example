# Railway crea automáticamente DATABASE_URL cuando agregas el plugin
# de PostgreSQL al proyecto. No necesitas configurarla manualmente.
# Este archivo es solo de referencia / para pruebas locales.

DATABASE_URL=postgresql://usuario:password@localhost:5432/orellanas

# Estas variables son opcionales: por defecto el backend usa el mismo
# broker público que el ESP32 (broker.hivemq.com). Solo cámbialas si
# vas a usar un broker distinto.
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_CLIENT_ID=orellanas-backend
